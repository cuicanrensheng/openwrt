# ==============================================
# 小米 R4AC 百兆版 专属 OpenWrt 编译配置
# ==============================================
# 目标平台（绝对不能错，OpenWrt 官方标准命名）
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7620a=y
CONFIG_TARGET_ramips_mt7620a_DEVICE_miwifi_r4ac=y

# ==============================================
# WiFi 驱动（R4AC 核心，必须开启）
# ==============================================
CONFIG_PACKAGE_kmod-mt76=y
CONFIG_PACKAGE_kmod-mt76x0e=y
CONFIG_PACKAGE_kmod-mt76x02-common=y
CONFIG_PACKAGE_kmod-mac80211=y
CONFIG_PACKAGE_kmod-cfg80211=y

# ==============================================
# LuCI Web 管理界面（必须开启）
# ==============================================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-opkg=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-mod-network=y
CONFIG_PACKAGE_luci-mod-status=y
CONFIG_PACKAGE_luci-mod-system=y

# ==============================================
# 基础系统工具（必备）
# ==============================================
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_openssl-util=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-ohci=y

# ==============================================
# 固件格式配置（生成可刷入的 sysupgrade.bin）
# ==============================================
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_ROOTFS_SYSUPGRADE=y
CONFIG_TARGET_ROOTFS_PARTSIZE=128
